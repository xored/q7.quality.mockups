------=_.content-0a7243a0-75d3-3d5f-9791-539de0e5b7ac
Content-Type: text/ecl
Entry-Name: .content

global [val rcptt_version [list-plugins | foreach [val item]  {
	if [$item | get id | eq "org.eclipse.rcptt.tesla.swt"]{
    		$item | get version | split -sep "."|  to-list
	}
}]] 

global [val major [$rcptt_version  | get 0 | int] ]
global [val minor [$rcptt_version  | get 1 | int] ]
global [val v29 [or [$major | gt 2] [and [$major | eq 2] [$minor | gt 8]]]]

log $v29

with [get-view "Q7 Quality Mockups"] {
    get-tree | select "nebula/Nebula-Grid"
    with [get-group "Nebula-Grid"] {
	    with [ get-nebula-grid] {
		    get-item -path Item | get-item-cell -column Name | double-click
			select  "Item/Child 1" 
	    }
	    if [ $v29 ] {
		    with [ get-nebula-grid] {
		    	get-cell -row 3 -column 2 | click
		    }
		    get-editbox | set-text "test1"
		    with [ get-nebula-grid] {
			    get-cell -row 1 -column 1 | click
			    get-cell -row 3 -column 2 | get-text | equals "test1" | verify-true
			    get-cell -row 3 -column 0 | get-text | equals "Editable Item" | verify-true
		    }
	    }
    }
}

